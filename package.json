{
  "name": "electron-deeplinking-macos-win32",
  "version": "0.0.1",
  "description": "A minimal Electron application with deep inking (macOS/win32/linux)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "build --dir",
    "dist": "build --config ./electron-builder.yaml"
  },
  "repository": "https://github.com/oikonomopo/electron-deep-linking-osx",
  "keywords": [
    "Electron",
    "macOS",
    "win32",
    "linux",
    "deep linking"
  ],
  "author": "oikonomopo",
  "license": "CC0-1.0",
  "devDependencies": {
    "electron": "^12.0.0",
    "electron-builder": "^20.40.2"
  },
  "build": {
    "appId": "com.myapp.myapp",
    "protocols": {
      "name": "myapp",
      "schemes": [
        "myapp"
      ]
    },
    "mac": {
      "category": "public.app-category.Reference"
    },
    "win": {},
    "linux":{
      "name": "myapp",
      "exec": "myapp %u",
      "category": "Utility",
      "mimeTypes": "x-scheme-handler/myapp",
      "artifactName": "myapp"
    }
  }
}
