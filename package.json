{
  "name": "electron-deeplinking-macos-win32",
  "version": "0.0.1",
  "description": "A minimal Electron application with deep inking (macOS/win32/linux)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "build --dir",
    "dist": "electron-builder --config ./electron-builder.yaml",
    "dist2": "build"
  },
  "repository": "https://github.com/oikonomopo/electron-deep-linking-osx",
  "keywords": [
    "Electron",
    "macOS",
    "win32",
    "linux",
    "deep linking"
  ],
  "author": "oikonomopo",
  "license": "CC0-1.0",
  "devDependencies": {
    "electron": "^12.0.0",
    "electron-builder": "^22.10.5"
  },
  "build": {
    "appId": "com.myapp.myapp",
    "protocols": {
      "name": "myapp",
      "schemes": [
        "myapp"
      ]
    },
    "mac": {
      "category": "public.app-category.Reference"
    },
    "win": {},
    "linux": {
      "target": [
        {
          "target": "AppImage"
        }
      ],
      "maintainer": "Jibra",
      "synopsis": "Some Stuff",
      "category": "Utility",
      "artifactName": "myapp.${ext}",
      "desktop": {
        "Name": "myapp",
        "Terminal": "false",
        "exec": "myapp %u",
        "mimeTypes": [
          "x-scheme-handler/myapp"
        ]
      }
    }
  }
}
